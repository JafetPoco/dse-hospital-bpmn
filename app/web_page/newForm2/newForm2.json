  "variables" : {
    "task" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.ordenPago ){",
        "\treturn {",
        "\t\t//map ordenPago variable to expected task contract input",
        "\t\tordenPagoInput: {",
        "\t\t\tidUser: $data.ordenPago.idUser !== undefined ? $data.ordenPago.idUser : null,",
        "\t\t\tpago: $data.ordenPago.pago !== undefined ? $data.ordenPago.pago : null,",
        "\t\t\ttipoPrueba: $data.ordenPago.tipoPrueba !== undefined ? $data.ordenPago.tipoPrueba : null,",
        "\t\t\tcosto: $data.ordenPago.costo !== undefined ? $data.ordenPago.costo : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "ordenPago" : {
      "type" : "url",
      "value" : [
        "../{{context.ordenPago_ref.link}}"
      ],
      "exposed" : false
    },
    "taskId" : {
      "type" : "urlparameter",
      "value" : [
        "id"
      ],
      "exposed" : false
    }
